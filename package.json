{
  "name": "fullstack-challenge",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for fullstack challenge",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "prettier": "@repo/prettier-config",
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.3"
  },
  "lint-staged": {
    "*.{js,ts,tsx,mjs}": [
      "eslint --fix"
    ],
    "*.{js,ts,tsx,mjs,css,md,json}": [
      "prettier --write"
    ]
  }
}
